{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "setCacheKey": true
      }
    }
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git push*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf *": "ask",
      "mv /*": "ask",
      "mv / *": "ask",
      "dd *": "deny",
      "mkfs*": "deny",
      "fdisk *": "deny",
      "mount *": "deny",
      "umount *": "deny",
      "chmod -R *": "ask",
      "chown -R *": "ask",
      "sudo *": "deny"
    },
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": false
    }
  }
}
