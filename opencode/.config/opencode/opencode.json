{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "setCacheKey": true
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "git status*": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": false
    }
  }
}
