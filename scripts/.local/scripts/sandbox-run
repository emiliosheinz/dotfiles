#!/usr/bin/env zsh
# sandbox-run: launch an agent under sandbox-exec.
# Always renders a temp policy file so SANDBOX_HOME_DIR is substituted with
# the real HOME, making agents.sb portable across machines (personal, spoke).
# Always injects ancestor file-read* literals and a file-read* file-write*
# subpath rule for the CWD, scoping write access to the current project.
#
# When the CWD is inside ~/dev/.worktrees/, additional grants are injected so
# git operations can reach the bare repo at ~/dev/<repo>:
#   - CWD = ~/dev/.worktrees/<branch>/<repo> (or deeper) → grants ~/dev/<repo>
#   - CWD = ~/dev/.worktrees/<branch>          → grants ~/dev (multi-repo case)
# Outside ~/dev/.worktrees/, no extra grants are emitted.
#
# Usage:
#   sandbox-run claude [args...]
#   sandbox-run opencode [args...]

set -euo pipefail

readonly HOME_DIR="${HOME}"
readonly WORKDIR="$(pwd -P)"
readonly PROFILE="${HOME_DIR}/dotfiles/sandbox/agents.sb"

if [[ ! -f "${PROFILE}" ]]; then
    print -u2 "sandbox-run: profile not found: ${PROFILE}"
    exit 1
fi

case "${1:-}" in
    claude)
        AGENT_BIN="${HOME_DIR}/.local/bin/claude"
        ;;
    opencode)
        AGENT_BIN="${HOME_DIR}/.homebrew/bin/opencode"
        ;;
    *)
        print -u2 "Usage: sandbox-run <claude|opencode> [args...]"
        exit 1
        ;;
esac
shift

if [[ ! -x "${AGENT_BIN}" ]]; then
    print -u2 "sandbox-run: agent binary not found or not executable: ${AGENT_BIN}"
    exit 1
fi

# Always render to a temp file so SANDBOX_HOME_DIR is replaced with the real HOME.
TMPFILE="$(mktemp /tmp/sandbox-run-XXXXXX)"
trap 'rm -f "${TMPFILE}"' EXIT INT TERM

sed "s|SANDBOX_HOME_DIR|${HOME_DIR}|g" "${PROFILE}" > "${TMPFILE}"

# Reject paths that contain characters which would break or inject SBPL syntax.
# SBPL string literals are delimited by double-quotes; a bare quote or backslash
# in the path would malform the injected rule or allow rule injection.
if [[ "${WORKDIR}" =~ [\"\\] ]]; then
    print -u2 "sandbox-run: workdir contains characters unsafe for sandbox policy injection: ${WORKDIR}"
    exit 1
fi
{
    printf '\n;; Runtime workdir: %s\n' "${WORKDIR}"
    local ancestor=""
    local -a parts
    parts=("${(@s:/:)WORKDIR}")
    for part in "${parts[@]}"; do
        [[ -z "${part}" ]] && continue
        ancestor="${ancestor}/${part}"
        printf '(allow file-read* (literal "%s"))\n' "${ancestor}"
    done
    printf '(allow file-read* file-write* (subpath "%s"))\n' "${WORKDIR}"
} >> "${TMPFILE}"

# Multi-repo isolation injection. Three CWD depths get distinct treatment:
#   ~/dev                              → workspace resolved via `ws workspace`; shared isolation block
#   ~/dev/.worktrees/<branch>          → branch resolved from path; shared isolation block
#   ~/dev/.worktrees/<branch>/<repo>+  → narrow single-repo grant (~/dev/<repo>)
# Anything outside ~/dev or ~/dev/.worktrees/ falls through with no extra grants.
readonly DEV_DIR="${HOME_DIR}/dev"
readonly WT_ROOT="${DEV_DIR}/.worktrees"
readonly WS_BIN="${HOME_DIR}/.local/scripts/ws"

# Emit the shared multi-repo isolation block: allow writes broadly under ~/dev
# (for bare-repo metadata access), deny everything under ~/dev/.worktrees, then
# narrowly re-allow the active branch's worktree. SBPL last-match-wins makes
# the active branch reachable while other branches' worktrees are sealed off.
emit_isolation_block() {
    local branch="$1"
    printf '\n;; Multi-repo isolation: active branch = %s\n' "${branch}"
    printf '(allow file-read* file-write* (subpath "%s"))\n' "${DEV_DIR}"
    printf '(deny file-read* file-write* (subpath "%s"))\n' "${WT_ROOT}"
    printf '(allow file-read* (literal "%s"))\n' "${WT_ROOT}"
    printf '(allow file-read* (literal "%s/%s"))\n' "${WT_ROOT}" "${branch}"
    printf '(allow file-read* file-write* (subpath "%s/%s"))\n' "${WT_ROOT}" "${branch}"
}

ACTIVE_BRANCH=""
ACTIVE_REPO=""
if [[ "${WORKDIR}" == "${DEV_DIR}" ]]; then
    # CWD = ~/dev/: resolve active workspace via the shared resolver. Failure
    # (backstage / outside tmux) aborts before any rules are rendered so we
    # never launch with a degraded grant. `ws workspace` writes the recovery
    # message to stderr, which propagates to our caller via shell.
    if ! ACTIVE_BRANCH=$("${WS_BIN}" workspace); then
        exit 1
    fi
elif [[ "${WORKDIR}" == "${WT_ROOT}"/* ]]; then
    WT_REL="${WORKDIR#${WT_ROOT}/}"
    local -a wt_parts
    wt_parts=("${(@s:/:)WT_REL}")
    ACTIVE_BRANCH="${wt_parts[1]}"
    ACTIVE_REPO="${wt_parts[2]:-}"
fi

if [[ -n "${ACTIVE_BRANCH}" ]]; then
    # Defense in depth: WORKDIR already passed the "/\ check above, but each
    # derived component is re-validated so any failure points at the offender.
    if [[ "${ACTIVE_BRANCH}" =~ [\"\\] ]]; then
        print -u2 "sandbox-run: active branch contains characters unsafe for sandbox policy injection: ${ACTIVE_BRANCH}"
        exit 1
    fi
    if [[ -n "${ACTIVE_REPO}" && "${ACTIVE_REPO}" =~ [\"\\] ]]; then
        print -u2 "sandbox-run: worktree repo component contains characters unsafe for sandbox policy injection: ${ACTIVE_REPO}"
        exit 1
    fi

    {
        if [[ -n "${ACTIVE_REPO}" ]]; then
            printf '\n;; Worktree injection: repo-folder CWD %s\n' "${WORKDIR}"
            printf '(allow file-read* (literal "%s"))\n' "${DEV_DIR}"
            printf '(allow file-read* (literal "%s/%s"))\n' "${DEV_DIR}" "${ACTIVE_REPO}"
            printf '(allow file-read* file-write* (subpath "%s/%s"))\n' "${DEV_DIR}" "${ACTIVE_REPO}"
        else
            emit_isolation_block "${ACTIVE_BRANCH}"
        fi
    } >> "${TMPFILE}"
fi

# Debug aid: when SANDBOX_RUN_PRINT_POLICY=1, emit the rendered policy and exit
# without launching the agent. Used for smoke-testing the rule rendering.
if [[ -n "${SANDBOX_RUN_PRINT_POLICY:-}" ]]; then
    cat "${TMPFILE}"
    exit 0
fi

# COLUMNS is a zsh-internal variable; export it so subprocesses (Node.js, tput)
# can detect the real terminal width inside the sandbox.
(( COLUMNS > 0 )) || COLUMNS=$(stty size </dev/tty 2>/dev/null | awk '{print $2}')
export COLUMNS

exec sandbox-exec -f "${TMPFILE}" "${AGENT_BIN}" "$@"
