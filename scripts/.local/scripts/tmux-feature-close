#!/usr/bin/env bash

get_feature_sessions() {
    tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^ws-"
}

selected=$(get_feature_sessions | fzf --prompt="close feature: ")

if [[ -z $selected ]]; then
    exit 0
fi

tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^ws-${selected}-" | while read -r session; do
    tmux kill-session -t "$session"
done

tmux kill-session -t "$selected"
