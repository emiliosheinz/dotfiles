#!/usr/bin/env bash
# Verify nothing emits cursor-blink-related escapes during idle in the current zsh.
# Exits 0 if the shell is silent during a 6s idle window, 1 otherwise.
#
# The intrinsic blink itself is invisible to this test (terminal-side rendering,
# not in the byte stream). The test guards against *future* regressions where a
# plugin starts emitting periodic cursor sequences — re-introducing the symptom
# in a way the existing nvim/zsh harnesses would not catch.
#
# See: .specs/bugs/ghostty-intrinsic-cursor-blink.md
set -euo pipefail
TMP=$(mktemp); trap 'rm -f "$TMP"' EXIT
WIN=$(tmux new-window -P -F '#{window_id}' -d -- zsh -i)
sleep 3
tmux send-keys -t "$WIN" "clear" Enter
sleep 0.5
tmux pipe-pane -t "$WIN" "cat > $TMP"
sleep 6
tmux pipe-pane -t "$WIN" ""
tmux send-keys -t "$WIN" "exit" Enter
sleep 0.4
tmux kill-window -t "$WIN" 2>/dev/null || true
bytes=$(wc -c < "$TMP" | tr -d ' ')
echo "idle bytes: $bytes"
[ "$bytes" -eq 0 ]
