#!/usr/bin/env bash

MODE="${1:-switch}"

get_workspaces() {
    tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^backstage-"
}

is_branch_shortcut() {
    # wt branch shortcuts (see https://worktrunk.dev/switch/): they resolve to
    # existing refs, so they must bypass our --create auto-injection.
    case "$1" in
        ^|-|@|pr:*|mr:*) return 0 ;;
        *) return 1 ;;
    esac
}

extract_wt_positionals() {
    # Walks wt-style args and separates positionals from flags. Knows which wt
    # flags take a separate value so the value is forwarded with its flag and
    # not mistaken for a positional. Everything after "--" (wt's EXECUTE_ARGS
    # separator) is forwarded verbatim.
    #
    # Sets globals:
    #   ws_positionals      array of positional args (in order)
    #   ws_forwarded_args   array of everything else, including "--" and after
    ws_positionals=()
    ws_forwarded_args=()
    local val_flags=("--base" "-b" "--execute" "-x" "--format" "-C" "--config")
    local args=("$@") i=0 n=${#args[@]}
    while [[ $i -lt $n ]]; do
        local arg="${args[$i]}"
        if [[ "$arg" == "--" ]]; then
            ws_forwarded_args+=("${args[@]:$i}")
            return 0
        fi
        local is_val_flag=false vf
        for vf in "${val_flags[@]}"; do
            if [[ "$arg" == "$vf" ]]; then
                is_val_flag=true; break
            fi
        done
        if $is_val_flag; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            if [[ $i -lt $n ]]; then
                ws_forwarded_args+=("${args[$i]}")
                i=$((i+1))
            fi
            continue
        fi
        # Any other flag (--base=val, --no-cd, -c, -vv, etc.); bare "-" is a
        # branch shortcut and falls through to positional.
        if [[ "$arg" != "-" && "$arg" == -* ]]; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            continue
        fi
        ws_positionals+=("$arg")
        i=$((i+1))
    done
}

needs_auto_create() {
    # Usage: needs_auto_create <branch> <repo_path_or_empty> [forwarded args...]
    # Returns 0 if we should inject --create.
    local branch="$1" repo_path="$2"
    shift 2
    is_branch_shortcut "$branch" && return 1
    local arg
    for arg in "$@"; do
        case "$arg" in
            --create|-c) return 1 ;;
        esac
    done
    if [[ -n "$repo_path" ]]; then
        git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    else
        git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    fi
    return 0
}

split_wt_execute_args() {
    # Splits args at the first "--" (wt's EXECUTE_ARGS separator).
    # Sets globals: wt_pre_args, wt_post_args, wt_saw_dashes ("true"/"false").
    wt_pre_args=()
    wt_post_args=()
    wt_saw_dashes=false
    local arg seen=false
    for arg in "$@"; do
        if ! $seen && [[ "$arg" == "--" ]]; then
            seen=true
            wt_saw_dashes=true
            continue
        fi
        if $seen; then
            wt_post_args+=("$arg")
        else
            wt_pre_args+=("$arg")
        fi
    done
}

remove_workspace_worktrees() {
    # Runs `wt remove` for every repo subdirectory under
    # ~/dev/.worktrees/<workspace>/, then cleans up the workspace folder.
    # The filesystem is the sole source of truth — a repo without a subdir
    # here is untouched (any lingering git-side registration is left as
    # manual cleanup).
    #
    # Usage: remove_workspace_worktrees <workspace> <mode>
    #   mode=kill    unconditional --force --force-delete; no prompt;
    #                final cleanup is `rm -rf` (kill is the "burn it down" verb).
    #   mode=remove  soft --foreground first; on dirty/unmerged, prompt once
    #                to re-run with --force --force-delete; final cleanup is
    #                `rmdir` (only removes if empty; caller-visible non-zero
    #                exit if not).
    #
    # --foreground is required: without it `wt remove` returns before the
    # worktree dir is gone, and the trailing rm/rmdir loses the race.
    #
    # Preserving .spec/* and pruning empty parent dirs happen in wt's
    # pre-remove/post-remove hooks (see ~/.config/worktrunk/config.toml).
    local workspace="$1"
    local mode="$2"
    local worktrees_root="$HOME/dev/.worktrees"
    local root="$worktrees_root/$workspace"

    local repos_list=""
    if [[ -d "$root" ]]; then
        repos_list=$(find "$root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | awk 'NF && !seen[$0]++')
    fi

    if [[ -z "$repos_list" ]]; then
        return 0
    fi

    local dirty_repos=() unmerged_repos=()
    local repo_dir repo_name output exit_code tail line src

    if [[ "$mode" == "kill" ]]; then
        echo "ws kill: $workspace"
        echo "  removing worktrees + local branches..."
    else
        echo "ws wt remove: $workspace"
    fi

    while IFS= read -r repo_name; do
        [[ -z "$repo_name" ]] && continue
        repo_dir="$root/$repo_name"
        echo "  - $repo_name: removing..."
        if [[ "$mode" == "kill" ]]; then
            output=$( (cd "$repo_dir" && wt remove --force --force-delete --foreground "$workspace" </dev/null) 2>&1 )
        else
            output=$( (cd "$repo_dir" && wt remove --foreground "$workspace" </dev/null) 2>&1 )
        fi
        exit_code=$?
        tail=$(printf '%s' "$output" | tail -n 3)
        if [[ $exit_code -ne 0 ]]; then
            if [[ "$mode" == "remove" ]] && printf '%s' "$output" | grep -qi "uncommitted changes"; then
                dirty_repos+=("$repo_name")
                echo "    dirty — uncommitted changes"
            else
                echo "    failed (exit $exit_code)"
            fi
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
        elif [[ "$mode" == "remove" ]] && printf '%s' "$output" | grep -qi "branch unmerged"; then
            unmerged_repos+=("$repo_name")
            echo "    unmerged — worktree removed, branch kept"
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
        else
            echo "    removed"
        fi
    done <<< "$repos_list"

    if [[ "$mode" == "remove" ]]; then
        local need_force=$((${#dirty_repos[@]} + ${#unmerged_repos[@]}))
        if [[ $need_force -gt 0 && -r /dev/tty ]]; then
            local answer=""
            printf '  Force remove %d pending worktree(s) with --force --force-delete? [y/N] ' "$need_force" >&2
            IFS= read -r answer </dev/tty
            if [[ "$answer" == [yY] || "$answer" == [yY][eE][sS] ]]; then
                for repo_name in "${dirty_repos[@]}" "${unmerged_repos[@]}"; do
                    repo_dir="$root/$repo_name"
                    echo "  - $repo_name: force-removing..."
                    if [[ -d "$repo_dir" ]]; then
                        output=$( (cd "$repo_dir" && wt remove --force --force-delete --foreground "$workspace" </dev/null) 2>&1 )
                        exit_code=$?
                    else
                        # Worktree already gone (unmerged case): rerun from
                        # source repo to also delete the branch.
                        src="$HOME/dev/$repo_name"
                        if [[ -d "$src" ]]; then
                            output=$( wt -C "$src" remove --force --force-delete --foreground "$workspace" </dev/null 2>&1 )
                            exit_code=$?
                        else
                            output="cannot locate source repo at $src"
                            exit_code=1
                        fi
                    fi
                    if [[ $exit_code -eq 0 ]]; then
                        echo "    force-removed"
                    else
                        echo "    force-remove failed (exit $exit_code)"
                        while IFS= read -r line; do
                            [[ -n "$line" ]] && echo "      $line"
                        done <<< "$(printf '%s' "$output" | tail -n 3)"
                    fi
                done
            fi
        fi
    fi

    if [[ "$mode" == "kill" ]]; then
        if [[ -d "$root" ]]; then
            rm -rf "$root"
            if [[ ! -d "$root" ]]; then
                echo "  workspace folder: removed"
            else
                echo "  workspace folder: left in place ($root)"
            fi
        fi
        return 0
    fi

    if [[ ! -d "$root" ]]; then
        return 0
    fi
    if rmdir "$root" 2>/dev/null; then
        echo "  workspace folder: removed"
        return 0
    fi
    echo "  workspace folder: left in place ($root)"
    return 1
}

resolve_workspace() {
    # Backstage sessions are named `backstage-<parent>`. Derive the parent by
    # stripping the prefix — the naming convention survives tmux restore,
    # whereas the @parent_session user option does not.
    if [[ -z "$TMUX" ]]; then
        return 1
    fi
    local session
    session=$(tmux display-message -p '#S' 2>/dev/null)
    if [[ -z "$session" ]]; then
        return 1
    fi
    if [[ "$session" == backstage-* ]]; then
        session="${session#backstage-}"
        if [[ -z "$session" ]] || ! tmux has-session -t "$session" 2>/dev/null; then
            return 1
        fi
    fi
    printf '%s\n' "$session"
}

print_top_usage() {
    cat <<'EOF'
Usage: ws <command> [args...]

Commands:
  switch [name]         fzf-pick or type a workspace to switch to (or create)
  kill                  fzf-pick a workspace to kill (removes its worktrees and tears down its tmux sessions)
  workspace             print the active workspace name; refuses on backstage / outside tmux
  wt <verb> [args...]   worktree operations (see `ws wt help`)
  help                  show this help

Running `ws` with no arguments defaults to `ws switch`.
EOF
}

print_wt_usage() {
    cat <<'EOF'
Usage: ws wt <subcommand> [args...]

Subcommands:
  switch [<workspace>] [-b <base>] [wt-flags...]
      switch to the worktree for <workspace> (defaults to the active workspace)
  add <repo> [<workspace>] [-b <base>] [wt-flags...]
      materialize a worktree for <workspace> in ~/dev/<repo> without changing CWD
  remove
      fzf-pick a workspace folder under ~/dev/.worktrees and remove every worktree in it
  help
      show this help
EOF
}

case "$MODE" in
    help|-h|--help)
        print_top_usage
        exit 0
        ;;
    workspace)
        if workspace=$(resolve_workspace); then
            printf '%s\n' "$workspace"
            exit 0
        fi
        echo "ws workspace: no active workspace resolvable. Launch from a workspace pane (tmux session named after the workspace) or cd into a worktree under ~/dev/.worktrees/<workspace>/." >&2
        exit 1
        ;;
    switch)
        result=$(get_workspaces | fzf --expect=alt-enter --print-query --prompt="workspace: ")

        query=$(printf "%s" "$result" | head -1)
        key=$(printf "%s" "$result" | sed -n '2p')
        selected=$(printf "%s" "$result" | sed -n '3p')

        # alt-enter on an existing workspace whose backstage exists: jump
        # straight to the backstage. Every other case falls through to the
        # standard switch-or-create-workspace path below.
        if [[ "$key" == "alt-enter" && -n "$selected" ]] && tmux has-session -t "backstage-${selected}" 2>/dev/null; then
            if [[ -z $TMUX ]]; then
                tmux attach-session -t "backstage-${selected}"
            else
                tmux switch-client -t "backstage-${selected}"
            fi
            exit 0
        fi

        if [[ -n $selected ]]; then
            session_name="$selected"
        elif [[ -n $query ]]; then
            session_name=$(echo "$query" | tr ' .' '-' | sed -E 's/-+$//')
        else
            exit 0
        fi

        tmux_running=$(pgrep tmux)

        if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
            tmux new-session -ds "$session_name" -c "$HOME"
            tmux attach-session -t "$session_name"
            exit 0
        fi

        if ! tmux has-session -t="$session_name" 2>/dev/null; then
            tmux new-session -ds "$session_name" -c "$HOME"
        fi

        if [[ -z $TMUX ]]; then
            tmux attach-session -t "$session_name"
        else
            tmux switch-client -t "$session_name"
        fi
        ;;
    kill)
        selected=$(get_workspaces | fzf --prompt="workspace: ")

        if [[ -z $selected ]]; then
            exit 0
        fi

        # Clean worktrees first: killing the session that hosts this script
        # would terminate the cleanup mid-run.
        remove_workspace_worktrees "$selected" kill

        tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -E "^backstage-${selected}(-|$)" | while read -r session; do
            tmux kill-session -t "$session"
        done

        tmux kill-session -t "$selected"
        ;;
    wt)
        subcommand="${2:-}"
        case "$subcommand" in
            help|-h|--help)
                print_wt_usage
                exit 0
                ;;
            switch)
                shift 2  # drop "wt" and "switch"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 1 ]]; then
                    echo "ws wt switch: unexpected extra positional '${ws_positionals[1]}'. Usage: ws wt switch [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                workspace="${ws_positionals[0]:-}"
                if [[ -z "$workspace" ]]; then
                    workspace=$(resolve_workspace) || true
                fi
                if [[ -z "$workspace" ]]; then
                    echo "ws wt switch: workspace required. Pass a workspace argument (ws wt switch <workspace> [-b <base>] [wt-flags...]) or run from inside a workspace pane." >&2
                    exit 1
                fi

                create_flag=()
                if needs_auto_create "$workspace" "" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                split_wt_execute_args "${ws_forwarded_args[@]}"
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$workspace" -- "${wt_post_args[@]}"
                else
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$workspace"
                fi
                ;;
            remove)
                worktrees_root="$HOME/dev/.worktrees"
                if [[ ! -d "$worktrees_root" ]]; then
                    echo "ws wt remove: $worktrees_root does not exist." >&2
                    exit 1
                fi

                workspace=$(find "$worktrees_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | fzf --prompt="worktree: ")
                if [[ -z "$workspace" ]]; then
                    exit 0
                fi

                remove_workspace_worktrees "$workspace" remove
                exit $?
                ;;
            add)
                shift 2  # drop "wt" and "add"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 2 ]]; then
                    echo "ws wt add: unexpected extra positional '${ws_positionals[2]}'. Usage: ws wt add <repo> [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                repo="${ws_positionals[0]:-}"
                if [[ -z "$repo" ]]; then
                    echo "ws wt add: repo name required. Usage: ws wt add <repo> [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                repo_path="$HOME/dev/$repo"
                if [[ ! -d "$repo_path" ]]; then
                    echo "ws wt add: $repo_path does not exist." >&2
                    exit 1
                fi
                if ! git -C "$repo_path" rev-parse --git-dir >/dev/null 2>&1; then
                    echo "ws wt add: $repo_path is not a git repository." >&2
                    exit 1
                fi
                workspace="${ws_positionals[1]:-}"
                if [[ -z "$workspace" ]]; then
                    if ! workspace=$(resolve_workspace); then
                        echo "ws wt add: no workspace resolvable. Pass an explicit workspace (ws wt add $repo <workspace> [-b <base>] [wt-flags...]), launch from a workspace pane, or cd into a worktree under ~/dev/.worktrees/<workspace>/." >&2
                        exit 1
                    fi
                fi

                create_flag=()
                if needs_auto_create "$workspace" "$repo_path" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                split_wt_execute_args "${ws_forwarded_args[@]}"
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$workspace" -- "${wt_post_args[@]}"
                else
                    wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$workspace"
                fi
                exit $?
                ;;
            *)
                echo "ws wt: unknown subcommand: ${subcommand:-<none>}" >&2
                print_wt_usage >&2
                exit 1
                ;;
        esac
        ;;
    backstage)
        subcommand="${2:-}"
        case "$subcommand" in
            enter)
                session_name="$3"
                current_path="$4"

                target="backstage-${session_name}"

                if ! tmux has-session -t "$target" 2>/dev/null; then
                    tmux new-session -d -s "$target" -c "$current_path"
                fi

                tmux switch-client -t "$target"
                ;;
            leave)
                # Parent is derived from the `backstage-<parent>` naming
                # convention so it survives tmux restore (user options do not).
                backstage_session="$3"

                parent=""
                if [[ "$backstage_session" == backstage-* ]]; then
                    parent="${backstage_session#backstage-}"
                fi
                if [ -z "$parent" ] || ! tmux has-session -t "$parent" 2>/dev/null; then
                    parent=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^backstage-' | head -1)
                fi
                [ -n "$parent" ] && tmux switch-client -t "$parent" || tmux detach-client
                ;;
        esac
        ;;
    *)
        echo "ws: unknown subcommand: ${MODE}" >&2
        print_top_usage >&2
        exit 1
        ;;
esac
