#!/usr/bin/env bash

MODE="${1:-switch}"

get_workspaces() {
    tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^backstage-"
}

is_branch_shortcut() {
    # wt branch shortcuts (see https://worktrunk.dev/switch/): they resolve to
    # existing refs, so they must bypass our --create auto-injection.
    case "$1" in
        ^|-|@|pr:*|mr:*) return 0 ;;
        *) return 1 ;;
    esac
}

extract_wt_positionals() {
    # Walks wt-style args and separates positionals from flags. Knows which wt
    # flags take a separate value so the value is forwarded with its flag and
    # not mistaken for a positional. Everything after "--" (wt's EXECUTE_ARGS
    # separator) is forwarded verbatim.
    #
    # Sets globals:
    #   ws_positionals      array of positional args (in order)
    #   ws_forwarded_args   array of everything else, including "--" and after
    ws_positionals=()
    ws_forwarded_args=()
    local val_flags=("--base" "-b" "--execute" "-x" "--format" "-C" "--config")
    local args=("$@") i=0 n=${#args[@]}
    while [[ $i -lt $n ]]; do
        local arg="${args[$i]}"
        if [[ "$arg" == "--" ]]; then
            ws_forwarded_args+=("${args[@]:$i}")
            return 0
        fi
        local is_val_flag=false vf
        for vf in "${val_flags[@]}"; do
            if [[ "$arg" == "$vf" ]]; then
                is_val_flag=true; break
            fi
        done
        if $is_val_flag; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            if [[ $i -lt $n ]]; then
                ws_forwarded_args+=("${args[$i]}")
                i=$((i+1))
            fi
            continue
        fi
        # Any other flag (--base=val, --no-cd, -c, -vv, etc.); bare "-" is a
        # branch shortcut and falls through to positional.
        if [[ "$arg" != "-" && "$arg" == -* ]]; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            continue
        fi
        ws_positionals+=("$arg")
        i=$((i+1))
    done
}

needs_auto_create() {
    # Usage: needs_auto_create <branch> <repo_path_or_empty> [forwarded args...]
    # Returns 0 if we should inject --create.
    local branch="$1" repo_path="$2"
    shift 2
    is_branch_shortcut "$branch" && return 1
    local arg
    for arg in "$@"; do
        case "$arg" in
            --create|-c) return 1 ;;
        esac
    done
    if [[ -n "$repo_path" ]]; then
        git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    else
        git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    fi
    return 0
}

split_wt_execute_args() {
    # Splits args at the first "--" (wt's EXECUTE_ARGS separator).
    # Sets globals: wt_pre_args, wt_post_args, wt_saw_dashes ("true"/"false").
    wt_pre_args=()
    wt_post_args=()
    wt_saw_dashes=false
    local arg seen=false
    for arg in "$@"; do
        if ! $seen && [[ "$arg" == "--" ]]; then
            seen=true
            wt_saw_dashes=true
            continue
        fi
        if $seen; then
            wt_post_args+=("$arg")
        else
            wt_pre_args+=("$arg")
        fi
    done
}

remove_worktrees_for_branch() {
    # Runs `wt remove --foreground` for every repo in the union of state's
    # active_repos ∪ subdirs of ~/dev/.worktrees/<branch>/. Streams a progress
    # line per repo, and — if any worktree was skipped due to uncommitted
    # changes or kept because the branch is unmerged — prompts once to re-run
    # those with --force --force-delete. State entries for repos whose
    # worktree dir is confirmed gone get pruned as we go. Finally rmdirs the
    # (now-empty) branch folder.
    #
    # --foreground is required: without it `wt remove` returns before the
    # worktree dir is gone, and the trailing rmdir loses the race.
    local branch="$1"
    local worktrees_root="$HOME/dev/.worktrees"
    local selected="$worktrees_root/$branch"

    local repos_list
    repos_list=$(
        {
            state_list_repos "$branch"
            [[ -d "$selected" ]] && find "$selected" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null
        } | awk 'NF && !seen[$0]++'
    )

    if [[ -z "$repos_list" ]]; then
        return 0
    fi

    local dirty_repos=()
    local unmerged_repos=()
    local repo_dir repo_name output exit_code tail line src

    echo "ws wt remove: $branch"

    while IFS= read -r repo_name; do
        [[ -z "$repo_name" ]] && continue
        repo_dir="$selected/$repo_name"
        echo "  - $repo_name: removing..."
        if [[ -d "$repo_dir" ]]; then
            output=$( (cd "$repo_dir" && wt remove --foreground "$branch" </dev/null) 2>&1 )
            exit_code=$?
        else
            # Tracked in state but the worktree dir is gone. Rerun from the
            # source repo so any lingering local branch also gets cleaned up.
            src="$HOME/dev/$repo_name"
            if [[ -d "$src" ]]; then
                echo "    (worktree dir missing; cleaning via $src)"
                output=$( wt -C "$src" remove --foreground "$branch" </dev/null 2>&1 )
                exit_code=$?
            else
                echo "    source repo missing at $HOME/dev/$repo_name; dropping from state"
                state_remove_repo "$branch" "$repo_name"
                continue
            fi
        fi
        tail=$(printf '%s' "$output" | tail -n 3)
        if [[ $exit_code -ne 0 ]]; then
            if printf '%s' "$output" | grep -qi "uncommitted changes"; then
                dirty_repos+=("$repo_name")
                echo "    dirty — uncommitted changes"
            else
                echo "    failed (exit $exit_code)"
            fi
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
        elif printf '%s' "$output" | grep -qi "branch unmerged"; then
            unmerged_repos+=("$repo_name")
            echo "    unmerged — worktree removed, branch kept"
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
            [[ ! -d "$repo_dir" ]] && state_remove_repo "$branch" "$repo_name"
        else
            echo "    removed"
            [[ ! -d "$repo_dir" ]] && state_remove_repo "$branch" "$repo_name"
        fi
    done <<< "$repos_list"

    local need_force=$((${#dirty_repos[@]} + ${#unmerged_repos[@]}))
    if [[ $need_force -gt 0 && -r /dev/tty ]]; then
        local answer=""
        printf '  Force remove %d pending worktree(s) with --force --force-delete? [y/N] ' "$need_force" >&2
        IFS= read -r answer </dev/tty
        if [[ "$answer" == [yY] || "$answer" == [yY][eE][sS] ]]; then
            for repo_name in "${dirty_repos[@]}" "${unmerged_repos[@]}"; do
                repo_dir="$selected/$repo_name"
                echo "  - $repo_name: force-removing..."
                if [[ -d "$repo_dir" ]]; then
                    output=$( (cd "$repo_dir" && wt remove --force --force-delete --foreground "$branch" </dev/null) 2>&1 )
                    exit_code=$?
                else
                    # Worktree already gone (unmerged case): rerun from source repo to delete the branch.
                    src="$HOME/dev/$repo_name"
                    if [[ -d "$src" ]]; then
                        output=$( wt -C "$src" remove --force --force-delete --foreground "$branch" </dev/null 2>&1 )
                        exit_code=$?
                    else
                        output="cannot locate source repo at $src"
                        exit_code=1
                    fi
                fi
                if [[ $exit_code -eq 0 ]]; then
                    echo "    force-removed"
                    [[ ! -d "$repo_dir" ]] && state_remove_repo "$branch" "$repo_name"
                else
                    echo "    force-remove failed (exit $exit_code)"
                    while IFS= read -r line; do
                        [[ -n "$line" ]] && echo "      $line"
                    done <<< "$(printf '%s' "$output" | tail -n 3)"
                fi
            done
        fi
    fi

    if [[ ! -d "$selected" ]]; then
        return 0
    fi
    if rmdir "$selected" 2>/dev/null; then
        echo "  workspace folder: removed"
        return 0
    fi
    echo "  workspace folder: left in place ($selected)"
    return 1
}

kill_workspace_worktrees() {
    # Tears down a workspace: `wt remove --force --force-delete --foreground`
    # for every repo in the state ∪ filesystem union, then wipes the leftover
    # ~/dev/.worktrees/<branch>/ folder as a backstop. Force is unconditional
    # — kill is already the "burn it down" verb.
    #
    # Preserving .spec/* and pruning empty parent dirs happen in wt's
    # pre-remove/post-remove hooks (see ~/.config/worktrunk/config.toml).
    #
    # --foreground is required: without it `wt remove` returns before the
    # worktree dir is gone, and the trailing rm loses the race.
    #
    # Note: per-repo state entries aren't pruned here — the caller in the
    # `kill)` case removes the entire workspace entry once tmux is torn down.
    local branch="$1"
    local worktrees_root="$HOME/dev/.worktrees"
    local branch_root="$worktrees_root/$branch"
    local repo_dir repo_name output exit_code line src

    local repos_list
    repos_list=$(
        {
            state_list_repos "$branch"
            [[ -d "$branch_root" ]] && find "$branch_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null
        } | awk 'NF && !seen[$0]++'
    )

    if [[ -z "$repos_list" ]]; then
        return 0
    fi

    echo "ws kill: $branch"

    echo "  removing worktrees + local branches..."
    while IFS= read -r repo_name; do
        [[ -z "$repo_name" ]] && continue
        repo_dir="$branch_root/$repo_name"
        echo "  - $repo_name: removing..."
        if [[ -d "$repo_dir" ]]; then
            output=$( (cd "$repo_dir" && wt remove --force --force-delete --foreground "$branch" </dev/null) 2>&1 )
            exit_code=$?
        else
            src="$HOME/dev/$repo_name"
            if [[ -d "$src" ]]; then
                echo "    (worktree dir missing; cleaning via $src)"
                output=$( wt -C "$src" remove --force --force-delete --foreground "$branch" </dev/null 2>&1 )
                exit_code=$?
            else
                echo "    source repo missing at $HOME/dev/$repo_name; skipping"
                continue
            fi
        fi
        if [[ $exit_code -eq 0 ]]; then
            echo "    removed"
        else
            echo "    failed (exit $exit_code)"
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$(printf '%s' "$output" | tail -n 3)"
        fi
    done <<< "$repos_list"

    if [[ -d "$branch_root" ]]; then
        rm -rf "$branch_root"
        if [[ ! -d "$branch_root" ]]; then
            echo "  workspace folder: removed"
        else
            echo "  workspace folder: left in place ($branch_root)"
        fi
    fi
}

resolve_branch() {
    # Backstage sessions are named `backstage-<parent>`. Derive the parent by
    # stripping the prefix — the naming convention survives tmux restore,
    # whereas the @parent_session user option does not.
    if [[ -z "$TMUX" ]]; then
        return 1
    fi
    local session
    session=$(tmux display-message -p '#S' 2>/dev/null)
    if [[ -z "$session" ]]; then
        return 1
    fi
    if [[ "$session" == backstage-* ]]; then
        session="${session#backstage-}"
        if [[ -z "$session" ]] || ! tmux has-session -t "$session" 2>/dev/null; then
            return 1
        fi
    fi
    printf '%s\n' "$session"
}

# ─────────────────────────────────────────────────────────────────────────────
# State: ~/.local/state/tmux-workspace-manager/state.json (schema v1).
# Atomic writes via .tmp + mv. All string inputs pass through --arg to avoid
# jq filter injection from branch/repo names.
# ─────────────────────────────────────────────────────────────────────────────

require_jq() {
    if ! command -v jq >/dev/null 2>&1; then
        echo "ws: jq is required. Install with 'brew install jq'." >&2
        exit 1
    fi
}

state_file() {
    printf '%s\n' "$HOME/.local/state/tmux-workspace-manager/state.json"
}

state_read() {
    local file
    file=$(state_file)
    if [[ -f "$file" ]]; then
        cat "$file"
    else
        printf '{"version":1,"workspaces":{}}\n'
    fi
}

state_write() {
    # stdin: full JSON to write. Refuses empty content so a mid-pipeline jq
    # failure can't clobber the file.
    local file tmp input
    file=$(state_file)
    mkdir -p "$(dirname "$file")" || return 1
    input=$(cat)
    if [[ -z "$input" ]]; then
        echo "ws state: refusing to write empty content" >&2
        return 1
    fi
    tmp="$file.tmp"
    printf '%s\n' "$input" > "$tmp" || return 1
    mv "$tmp" "$file"
}

state_upsert_workspace() {
    # Usage: state_upsert_workspace <worktree>
    local worktree="$1" out
    out=$(state_read | jq --arg wt "$worktree" '
        .workspaces[$wt] //= {worktree: $wt, backstage_session: null, active_repos: []}
    ') || return 1
    printf '%s\n' "$out" | state_write
}

state_remove_workspace() {
    # Usage: state_remove_workspace <worktree>
    local worktree="$1" out
    out=$(state_read | jq --arg wt "$worktree" 'del(.workspaces[$wt])') || return 1
    printf '%s\n' "$out" | state_write
}

state_set_backstage() {
    # Usage: state_set_backstage <worktree> <session_or_empty>
    # Empty session sets backstage_session to null. No-op if the workspace
    # entry does not exist (avoids materializing bogus workspaces).
    local worktree="$1" session="$2" out
    if [[ -z "$session" ]]; then
        out=$(state_read | jq --arg wt "$worktree" '
            if .workspaces[$wt] then .workspaces[$wt].backstage_session = null else . end
        ') || return 1
    else
        out=$(state_read | jq --arg wt "$worktree" --arg s "$session" '
            if .workspaces[$wt] then .workspaces[$wt].backstage_session = $s else . end
        ') || return 1
    fi
    printf '%s\n' "$out" | state_write
}

state_add_repo() {
    # Usage: state_add_repo <worktree> <repo> <base_branch_or_empty>
    # Idempotent: if repo is already listed, only fills a null base_branch;
    # never overwrites an existing non-null value.
    local worktree="$1" repo="$2" base="$3" out
    out=$(state_read | jq --arg wt "$worktree" --arg r "$repo" --arg b "$base" '
        (if $b == "" then null else $b end) as $base_val
        | .workspaces[$wt] //= {worktree: $wt, backstage_session: null, active_repos: []}
        | if any(.workspaces[$wt].active_repos[]; .repo == $r) then
              .workspaces[$wt].active_repos |= map(
                  if .repo == $r and .base_branch == null and $base_val != null
                  then .base_branch = $base_val
                  else . end
              )
          else
              .workspaces[$wt].active_repos += [{repo: $r, base_branch: $base_val}]
          end
    ') || return 1
    printf '%s\n' "$out" | state_write
}

state_remove_repo() {
    # Usage: state_remove_repo <worktree> <repo>
    local worktree="$1" repo="$2" out
    out=$(state_read | jq --arg wt "$worktree" --arg r "$repo" '
        if .workspaces[$wt] then
            .workspaces[$wt].active_repos |= map(select(.repo != $r))
        else . end
    ') || return 1
    printf '%s\n' "$out" | state_write
}

state_list_repos() {
    # Usage: state_list_repos <worktree>. Emits one repo per line.
    local worktree="$1"
    state_read | jq -r --arg wt "$worktree" '
        (.workspaces[$wt].active_repos // []) | .[] | .repo
    '
}

extract_base_branch() {
    # Walks the passed args (typically ws_forwarded_args) and echoes the value
    # of -b/--base if present. Handles "-b main" / "--base main" and the
    # "--base=main" form. Sync with val_flags in extract_wt_positionals if
    # wt's flag spec changes.
    local args=("$@") i=0 n=${#args[@]} arg
    while [[ $i -lt $n ]]; do
        arg="${args[$i]}"
        case "$arg" in
            --base=*)
                printf '%s\n' "${arg#--base=}"
                return 0
                ;;
            -b|--base)
                i=$((i+1))
                [[ $i -lt $n ]] && printf '%s\n' "${args[$i]}"
                return 0
                ;;
        esac
        i=$((i+1))
    done
}

require_jq

case "$MODE" in
    workspace)
        if branch=$(resolve_branch); then
            printf '%s\n' "$branch"
            exit 0
        fi
        echo "ws workspace: no active workspace resolvable. Launch from a workspace pane (tmux session named after the workspace) or cd into a worktree under ~/dev/.worktrees/<workspace>/." >&2
        exit 1
        ;;
    switch)
        result=$(get_workspaces | fzf --expect=alt-enter --print-query --prompt="workspace: ")

        query=$(printf "%s" "$result" | head -1)
        key=$(printf "%s" "$result" | sed -n '2p')
        selected=$(printf "%s" "$result" | sed -n '3p')

        # alt-enter on an existing workspace whose backstage exists: jump
        # straight to the backstage. Every other case falls through to the
        # standard switch-or-create-workspace path below.
        if [[ "$key" == "alt-enter" && -n "$selected" ]] && tmux has-session -t "backstage-${selected}" 2>/dev/null; then
            if [[ -z $TMUX ]]; then
                tmux attach-session -t "backstage-${selected}"
            else
                tmux switch-client -t "backstage-${selected}"
            fi
            exit 0
        fi

        if [[ -n $selected ]]; then
            session_name="$selected"
        elif [[ -n $query ]]; then
            session_name=$(echo "$query" | tr ' .' '-' | sed -E 's/-+$//')
        else
            exit 0
        fi

        state_upsert_workspace "$session_name"

        tmux_running=$(pgrep tmux)

        if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
            tmux new-session -ds "$session_name" -c "$HOME"
            tmux attach-session -t "$session_name"
            exit 0
        fi

        if ! tmux has-session -t="$session_name" 2>/dev/null; then
            tmux new-session -ds "$session_name" -c "$HOME"
        fi

        if [[ -z $TMUX ]]; then
            tmux attach-session -t "$session_name"
        else
            tmux switch-client -t "$session_name"
        fi
        ;;
    kill)
        selected=$(get_workspaces | fzf --prompt="workspace: ")

        if [[ -z $selected ]]; then
            exit 0
        fi

        # Clean worktrees first: killing the session that hosts this script
        # would terminate the cleanup mid-run.
        kill_workspace_worktrees "$selected"

        tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -E "^backstage-${selected}(-|$)" | while read -r session; do
            tmux kill-session -t "$session"
        done

        tmux kill-session -t "$selected"

        state_remove_workspace "$selected"
        ;;
    wt)
        subcommand="${2:-}"
        case "$subcommand" in
            switch)
                shift 2  # drop "wt" and "switch"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 1 ]]; then
                    echo "ws wt switch: unexpected extra positional '${ws_positionals[1]}'. Usage: ws wt switch [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                branch="${ws_positionals[0]:-}"
                if [[ -z "$branch" ]]; then
                    branch=$(resolve_branch) || true
                fi
                if [[ -z "$branch" ]]; then
                    echo "ws wt switch: workspace required. Pass a workspace argument (ws wt switch <workspace> [-b <base>] [wt-flags...]) or run from inside a workspace pane." >&2
                    exit 1
                fi

                create_flag=()
                if needs_auto_create "$branch" "" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                split_wt_execute_args "${ws_forwarded_args[@]}"
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$branch" -- "${wt_post_args[@]}"
                else
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$branch"
                fi
                ;;
            remove)
                worktrees_root="$HOME/dev/.worktrees"
                if [[ ! -d "$worktrees_root" ]]; then
                    echo "ws wt remove: $worktrees_root does not exist." >&2
                    exit 1
                fi

                branch=$(find "$worktrees_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | fzf --prompt="worktree: ")
                if [[ -z "$branch" ]]; then
                    exit 0
                fi

                remove_worktrees_for_branch "$branch"
                exit $?
                ;;
            add)
                shift 2  # drop "wt" and "add"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 2 ]]; then
                    echo "ws wt add: unexpected extra positional '${ws_positionals[2]}'. Usage: ws wt add <repo> [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                repo="${ws_positionals[0]:-}"
                if [[ -z "$repo" ]]; then
                    echo "ws wt add: repo name required. Usage: ws wt add <repo> [<workspace>] [-b <base>] [wt-flags...]" >&2
                    exit 1
                fi
                repo_path="$HOME/dev/$repo"
                if [[ ! -d "$repo_path" ]]; then
                    echo "ws wt add: $repo_path does not exist." >&2
                    exit 1
                fi
                if ! git -C "$repo_path" rev-parse --git-dir >/dev/null 2>&1; then
                    echo "ws wt add: $repo_path is not a git repository." >&2
                    exit 1
                fi
                branch="${ws_positionals[1]:-}"
                if [[ -z "$branch" ]]; then
                    if ! branch=$(resolve_branch); then
                        echo "ws wt add: no workspace resolvable. Pass an explicit workspace (ws wt add $repo <workspace> [-b <base>] [wt-flags...]), launch from a workspace pane, or cd into a worktree under ~/dev/.worktrees/<workspace>/." >&2
                        exit 1
                    fi
                fi

                create_flag=()
                if needs_auto_create "$branch" "$repo_path" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                base_branch=$(extract_base_branch "${ws_forwarded_args[@]}")

                split_wt_execute_args "${ws_forwarded_args[@]}"
                # Run wt as a child (not exec) so state can be updated after a
                # successful switch. `--no-cd` is passed anyway, so we're not
                # dropping any cd directive by giving up the tail call.
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$branch" -- "${wt_post_args[@]}"
                else
                    wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$branch"
                fi
                wt_exit=$?

                if [[ $wt_exit -eq 0 ]]; then
                    state_upsert_workspace "$branch"
                    state_add_repo "$branch" "$repo" "$base_branch"
                fi
                exit $wt_exit
                ;;
            *)
                echo "ws wt: unknown subcommand: ${subcommand:-<none>}" >&2
                echo "Usage: ws wt {switch [workspace] | add <repo> [workspace] | remove}" >&2
                exit 1
                ;;
        esac
        ;;
    backstage)
        subcommand="${2:-}"
        case "$subcommand" in
            enter)
                session_name="$3"
                current_path="$4"

                target="backstage-${session_name}"

                if ! tmux has-session -t "$target" 2>/dev/null; then
                    tmux new-session -d -s "$target" -c "$current_path"
                fi

                tmux switch-client -t "$target"

                # No-op if the parent workspace has no state entry yet.
                state_set_backstage "$session_name" "$target"
                ;;
            leave)
                # Parent is derived from the `backstage-<parent>` naming
                # convention so it survives tmux restore (user options do not).
                backstage_session="$3"

                parent=""
                if [[ "$backstage_session" == backstage-* ]]; then
                    parent="${backstage_session#backstage-}"
                fi
                if [ -z "$parent" ] || ! tmux has-session -t "$parent" 2>/dev/null; then
                    parent=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^backstage-' | head -1)
                fi
                [ -n "$parent" ] && tmux switch-client -t "$parent" || tmux detach-client
                ;;
        esac
        ;;
    migrate)
        # Seed the state file from live tmux sessions + ~/dev/.worktrees/.
        # Idempotent: existing entries are preserved; only missing bits are
        # filled in. Base branches are unknown at migrate time (recorded as
        # null); state_add_repo never overwrites a non-null base_branch.
        worktrees_root="$HOME/dev/.worktrees"
        migrated=0
        while IFS= read -r worktree; do
            [[ -z "$worktree" ]] && continue
            state_upsert_workspace "$worktree"

            repo_count=0
            if [[ -d "$worktrees_root/$worktree" ]]; then
                while IFS= read -r repo_name; do
                    [[ -z "$repo_name" ]] && continue
                    state_add_repo "$worktree" "$repo_name" ""
                    repo_count=$((repo_count + 1))
                done < <(find "$worktrees_root/$worktree" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null)
            fi

            backstage_flag="no"
            if tmux has-session -t "backstage-$worktree" 2>/dev/null; then
                state_set_backstage "$worktree" "backstage-$worktree"
                backstage_flag="yes"
            fi

            echo "migrated: $worktree ($repo_count repos, backstage: $backstage_flag)"
            migrated=$((migrated + 1))
        done < <(get_workspaces)

        if [[ $migrated -eq 0 ]]; then
            echo "ws migrate: no live workspaces to migrate."
        fi
        ;;
    *)
        echo "ws: unknown subcommand: ${MODE}" >&2
        echo "Usage: ws {switch | kill | workspace | wt <verb> | migrate}" >&2
        exit 1
        ;;
esac
