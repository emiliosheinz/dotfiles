#!/usr/bin/env bash

MODE="${1:-switch}"

get_workspaces() {
    tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^backstage-"
}

is_branch_shortcut() {
    # wt branch shortcuts (see https://worktrunk.dev/switch/): they resolve to
    # existing refs, so they must bypass our --create auto-injection.
    case "$1" in
        ^|-|@|pr:*|mr:*) return 0 ;;
        *) return 1 ;;
    esac
}

extract_wt_positionals() {
    # Walks wt-style args and separates positionals from flags. Knows which wt
    # flags take a separate value so the value is forwarded with its flag and
    # not mistaken for a positional. Everything after "--" (wt's EXECUTE_ARGS
    # separator) is forwarded verbatim.
    #
    # Sets globals:
    #   ws_positionals      array of positional args (in order)
    #   ws_forwarded_args   array of everything else, including "--" and after
    ws_positionals=()
    ws_forwarded_args=()
    local val_flags=("--base" "-b" "--execute" "-x" "--format" "-C" "--config")
    local args=("$@") i=0 n=${#args[@]}
    while [[ $i -lt $n ]]; do
        local arg="${args[$i]}"
        if [[ "$arg" == "--" ]]; then
            ws_forwarded_args+=("${args[@]:$i}")
            return 0
        fi
        local is_val_flag=false vf
        for vf in "${val_flags[@]}"; do
            if [[ "$arg" == "$vf" ]]; then
                is_val_flag=true; break
            fi
        done
        if $is_val_flag; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            if [[ $i -lt $n ]]; then
                ws_forwarded_args+=("${args[$i]}")
                i=$((i+1))
            fi
            continue
        fi
        # Any other flag (--base=val, --no-cd, -c, -vv, etc.); bare "-" is a
        # branch shortcut and falls through to positional.
        if [[ "$arg" != "-" && "$arg" == -* ]]; then
            ws_forwarded_args+=("$arg")
            i=$((i+1))
            continue
        fi
        ws_positionals+=("$arg")
        i=$((i+1))
    done
}

needs_auto_create() {
    # Usage: needs_auto_create <branch> <repo_path_or_empty> [forwarded args...]
    # Returns 0 if we should inject --create.
    local branch="$1" repo_path="$2"
    shift 2
    is_branch_shortcut "$branch" && return 1
    local arg
    for arg in "$@"; do
        case "$arg" in
            --create|-c) return 1 ;;
        esac
    done
    if [[ -n "$repo_path" ]]; then
        git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    else
        git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null && return 1
    fi
    return 0
}

split_wt_execute_args() {
    # Splits args at the first "--" (wt's EXECUTE_ARGS separator).
    # Sets globals: wt_pre_args, wt_post_args, wt_saw_dashes ("true"/"false").
    wt_pre_args=()
    wt_post_args=()
    wt_saw_dashes=false
    local arg seen=false
    for arg in "$@"; do
        if ! $seen && [[ "$arg" == "--" ]]; then
            seen=true
            wt_saw_dashes=true
            continue
        fi
        if $seen; then
            wt_post_args+=("$arg")
        else
            wt_pre_args+=("$arg")
        fi
    done
}

remove_worktrees_for_branch() {
    # Runs `wt remove --foreground` for every worktree under
    # ~/dev/.worktrees/<branch>/. Streams a progress line per repo as work
    # happens so the kill popup isn't blank during the run, and — if any
    # worktree was skipped due to uncommitted changes or kept because the
    # branch is unmerged — prompts once to re-run those with
    # --force --force-delete. Finally rmdirs the (now-empty) branch folder.
    #
    # --foreground is required: without it `wt remove` returns before the
    # worktree dir is gone, and the trailing rmdir loses the race.
    local branch="$1"
    local worktrees_root="$HOME/dev/.worktrees"
    local selected="$worktrees_root/$branch"

    if [[ ! -d "$selected" ]]; then
        return 0
    fi

    local dirty_repos=()
    local unmerged_repos=()
    local repo_dir repo_name output exit_code tail line

    echo "ws wt remove: $branch"

    while IFS= read -r -d '' repo_dir; do
        [[ -d "$repo_dir" ]] || continue
        repo_name=$(basename "$repo_dir")
        echo "  - $repo_name: removing..."
        output=$( (cd "$repo_dir" && wt remove --foreground "$branch" </dev/null) 2>&1 )
        exit_code=$?
        tail=$(printf '%s' "$output" | tail -n 3)
        if [[ $exit_code -ne 0 ]]; then
            if printf '%s' "$output" | grep -qi "uncommitted changes"; then
                dirty_repos+=("$repo_name")
                echo "    dirty — uncommitted changes"
            else
                echo "    failed (exit $exit_code)"
            fi
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
        elif printf '%s' "$output" | grep -qi "branch unmerged"; then
            unmerged_repos+=("$repo_name")
            echo "    unmerged — worktree removed, branch kept"
            while IFS= read -r line; do
                [[ -n "$line" ]] && echo "      $line"
            done <<< "$tail"
        else
            echo "    removed"
        fi
    done < <(find "$selected" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

    local need_force=$((${#dirty_repos[@]} + ${#unmerged_repos[@]}))
    if [[ $need_force -gt 0 && -r /dev/tty ]]; then
        local answer=""
        printf '  Force remove %d pending worktree(s) with --force --force-delete? [y/N] ' "$need_force" >&2
        IFS= read -r answer </dev/tty
        if [[ "$answer" == [yY] || "$answer" == [yY][eE][sS] ]]; then
            local src
            for repo_name in "${dirty_repos[@]}" "${unmerged_repos[@]}"; do
                repo_dir="$selected/$repo_name"
                echo "  - $repo_name: force-removing..."
                if [[ -d "$repo_dir" ]]; then
                    output=$( (cd "$repo_dir" && wt remove --force --force-delete --foreground "$branch" </dev/null) 2>&1 )
                    exit_code=$?
                else
                    # Worktree already gone (unmerged case): rerun from source repo to delete the branch.
                    src="$HOME/dev/$repo_name"
                    if [[ -d "$src" ]]; then
                        output=$( wt -C "$src" remove --force --force-delete --foreground "$branch" </dev/null 2>&1 )
                        exit_code=$?
                    else
                        output="cannot locate source repo at $src"
                        exit_code=1
                    fi
                fi
                if [[ $exit_code -eq 0 ]]; then
                    echo "    force-removed"
                else
                    echo "    force-remove failed (exit $exit_code)"
                    while IFS= read -r line; do
                        [[ -n "$line" ]] && echo "      $line"
                    done <<< "$(printf '%s' "$output" | tail -n 3)"
                fi
            done
        fi
    fi

    if rmdir "$selected" 2>/dev/null; then
        echo "  branch folder: removed"
        return 0
    fi
    echo "  branch folder: left in place ($selected)"
    return 1
}

resolve_branch() {
    if [[ -z "$TMUX" ]]; then
        return 1
    fi
    local session
    session=$(tmux display-message -p '#S' 2>/dev/null)
    if [[ -z "$session" ]]; then
        return 1
    fi
    if [[ "$session" == backstage-* ]]; then
        local parent
        parent=$(tmux show-options -t "$session" -qv @parent_session 2>/dev/null)
        if [[ -z "$parent" ]] || ! tmux has-session -t "$parent" 2>/dev/null; then
            return 1
        fi
        session="$parent"
    fi
    printf '%s\n' "$session"
}

case "$MODE" in
    branch)
        if branch=$(resolve_branch); then
            printf '%s\n' "$branch"
            exit 0
        fi
        echo "ws branch: no active branch resolvable. Launch from a workspace pane (tmux session named after the branch) or cd into a worktree under ~/dev/.worktrees/<branch>/." >&2
        exit 1
        ;;
    switch)
        result=$(get_workspaces | fzf --expect=alt-enter --print-query --prompt="workspace: ")

        query=$(printf "%s" "$result" | head -1)
        key=$(printf "%s" "$result" | sed -n '2p')
        selected=$(printf "%s" "$result" | sed -n '3p')

        # alt-enter on an existing workspace whose backstage exists: jump
        # straight to the backstage. Every other case falls through to the
        # standard switch-or-create-workspace path below.
        if [[ "$key" == "alt-enter" && -n "$selected" ]] && tmux has-session -t "backstage-${selected}" 2>/dev/null; then
            if [[ -z $TMUX ]]; then
                tmux attach-session -t "backstage-${selected}"
            else
                tmux switch-client -t "backstage-${selected}"
            fi
            exit 0
        fi

        if [[ -n $selected ]]; then
            session_name="$selected"
        elif [[ -n $query ]]; then
            session_name=$(echo "$query" | tr ' .' '-' | sed -E 's/-+$//')
        else
            exit 0
        fi

        tmux_running=$(pgrep tmux)

        if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
            tmux new-session -ds "$session_name" -c "$HOME"
            tmux attach-session -t "$session_name"
            exit 0
        fi

        if ! tmux has-session -t="$session_name" 2>/dev/null; then
            tmux new-session -ds "$session_name" -c "$HOME"
        fi

        if [[ -z $TMUX ]]; then
            tmux attach-session -t "$session_name"
        else
            tmux switch-client -t "$session_name"
        fi
        ;;
    kill)
        selected=$(get_workspaces | fzf --prompt="workspace: ")

        if [[ -z $selected ]]; then
            exit 0
        fi

        # Clean worktrees first: killing the session that hosts this script
        # would terminate the cleanup mid-run.
        remove_worktrees_for_branch "$selected"

        tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -E "^backstage-${selected}(-|$)" | while read -r session; do
            tmux kill-session -t "$session"
        done

        tmux kill-session -t "$selected"
        ;;
    wt)
        subcommand="${2:-}"
        case "$subcommand" in
            switch)
                shift 2  # drop "wt" and "switch"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 1 ]]; then
                    echo "ws wt switch: unexpected extra positional '${ws_positionals[1]}'. Usage: ws wt switch [<branch>] [wt-flags...]" >&2
                    exit 1
                fi
                branch="${ws_positionals[0]:-}"
                if [[ -z "$branch" ]]; then
                    branch=$(resolve_branch) || true
                fi
                if [[ -z "$branch" ]]; then
                    echo "ws wt switch: branch required. Pass a branch argument (ws wt switch <branch> [wt-flags...]) or run from inside the workspace session." >&2
                    exit 1
                fi

                create_flag=()
                if needs_auto_create "$branch" "" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                split_wt_execute_args "${ws_forwarded_args[@]}"
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$branch" -- "${wt_post_args[@]}"
                else
                    exec wt switch "${create_flag[@]}" "${wt_pre_args[@]}" "$branch"
                fi
                ;;
            remove)
                worktrees_root="$HOME/dev/.worktrees"
                if [[ ! -d "$worktrees_root" ]]; then
                    echo "ws wt remove: $worktrees_root does not exist." >&2
                    exit 1
                fi

                branch=$(find "$worktrees_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | fzf --prompt="worktree: ")
                if [[ -z "$branch" ]]; then
                    exit 0
                fi

                remove_worktrees_for_branch "$branch"
                exit $?
                ;;
            add)
                shift 2  # drop "wt" and "add"
                extract_wt_positionals "$@"
                if [[ ${#ws_positionals[@]} -gt 2 ]]; then
                    echo "ws wt add: unexpected extra positional '${ws_positionals[2]}'. Usage: ws wt add <repo> [<branch>] [wt-flags...]" >&2
                    exit 1
                fi
                repo="${ws_positionals[0]:-}"
                if [[ -z "$repo" ]]; then
                    echo "ws wt add: repo name required. Usage: ws wt add <repo> [<branch>] [wt-flags...]" >&2
                    exit 1
                fi
                repo_path="$HOME/dev/$repo"
                if [[ ! -d "$repo_path" ]]; then
                    echo "ws wt add: $repo_path does not exist." >&2
                    exit 1
                fi
                if ! git -C "$repo_path" rev-parse --git-dir >/dev/null 2>&1; then
                    echo "ws wt add: $repo_path is not a git repository." >&2
                    exit 1
                fi
                branch="${ws_positionals[1]:-}"
                if [[ -z "$branch" ]]; then
                    if ! branch=$(resolve_branch); then
                        echo "ws wt add: no branch resolvable. Pass an explicit branch (ws wt add $repo <branch> [wt-flags...]), launch from a workspace pane, or cd into a worktree under ~/dev/.worktrees/<branch>/." >&2
                        exit 1
                    fi
                fi

                create_flag=()
                if needs_auto_create "$branch" "$repo_path" "${ws_forwarded_args[@]}"; then
                    create_flag=(--create)
                fi

                split_wt_execute_args "${ws_forwarded_args[@]}"
                if [[ "$wt_saw_dashes" == "true" ]]; then
                    exec wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$branch" -- "${wt_post_args[@]}"
                else
                    exec wt -C "$repo_path" switch "${create_flag[@]}" --no-cd "${wt_pre_args[@]}" "$branch"
                fi
                ;;
            *)
                echo "ws wt: unknown subcommand: ${subcommand:-<none>}" >&2
                echo "Usage: ws wt {switch [branch] | add <repo> [branch] | remove}" >&2
                exit 1
                ;;
        esac
        ;;
    backstage)
        subcommand="${2:-}"
        case "$subcommand" in
            enter)
                session_name="$3"
                current_path="$4"

                target="backstage-${session_name}"

                if ! tmux has-session -t "$target" 2>/dev/null; then
                    tmux new-session -d -s "$target" -c "$current_path"
                fi
                tmux set-option -t "$target" @parent_session "$session_name"

                tmux switch-client -t "$target"
                ;;
            leave)
                backstage_session="$3"

                parent=$(tmux show-options -t "$backstage_session" -qv @parent_session 2>/dev/null)
                if [ -z "$parent" ] || ! tmux has-session -t "$parent" 2>/dev/null; then
                    parent=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^backstage-' | head -1)
                fi
                [ -n "$parent" ] && tmux switch-client -t "$parent" || tmux detach-client
                ;;
        esac
        ;;
esac
