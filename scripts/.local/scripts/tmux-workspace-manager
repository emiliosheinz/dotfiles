#!/usr/bin/env bash

MODE="${1:-switch}"

get_workspaces() {
    tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^backstage-"
}

case "$MODE" in
    switch)
        result=$(get_workspaces | fzf --print-query --prompt="workspace: ")

        query=$(printf "%s" "$result" | head -1)
        selected=$(printf "%s" "$result" | sed -n '2p')

        if [[ -n $selected ]]; then
            session_name="$selected"
        elif [[ -n $query ]]; then
            session_name=$(echo "$query" | tr ' .' '-' | sed -E 's/-+$//')
        else
            exit 0
        fi

        tmux_running=$(pgrep tmux)

        if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
            tmux new-session -ds "$session_name" -c "$HOME"
            tmux attach-session -t "$session_name"
            exit 0
        fi

        if ! tmux has-session -t="$session_name" 2>/dev/null; then
            tmux new-session -ds "$session_name" -c "$HOME"
        fi

        if [[ -z $TMUX ]]; then
            tmux attach-session -t "$session_name"
        else
            tmux switch-client -t "$session_name"
        fi
        ;;
    kill)
        selected=$(get_workspaces | fzf --prompt="workspace: ")

        if [[ -z $selected ]]; then
            exit 0
        fi

        tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^backstage-${selected}-" | while read -r session; do
            tmux kill-session -t "$session"
        done

        tmux kill-session -t "$selected"
        ;;
    wt)
        subcommand="${2:-}"
        case "$subcommand" in
            switch)
                branch="${3:-}"
                if [[ -z "$branch" && -n "$TMUX" ]]; then
                    session=$(tmux display-message -p '#S')
                    if [[ "$session" != backstage-* ]]; then
                        branch="$session"
                    fi
                fi
                if [[ -z "$branch" ]]; then
                    echo "ws wt switch: branch required. Pass a branch argument (ws wt switch <branch>) or run from inside the workspace session." >&2
                    exit 1
                fi

                if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
                    exec wt switch "$branch"
                else
                    exec wt switch --create "$branch"
                fi
                ;;
            remove)
                worktrees_root="$HOME/dev/.worktrees"
                if [[ ! -d "$worktrees_root" ]]; then
                    echo "ws wt remove: $worktrees_root does not exist." >&2
                    exit 1
                fi

                branch=$(find "$worktrees_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | fzf --prompt="worktree: ")
                if [[ -z "$branch" ]]; then
                    exit 0
                fi

                selected="$worktrees_root/$branch"
                removed=()
                skipped_names=()
                skipped_codes=()
                skipped_tails=()

                while IFS= read -r -d '' repo_dir; do
                    [[ -d "$repo_dir" ]] || continue
                    repo_name=$(basename "$repo_dir")
                    output=$( (cd "$repo_dir" && wt remove "$branch" </dev/null) 2>&1 )
                    exit_code=$?
                    if [[ $exit_code -eq 0 ]]; then
                        removed+=("$repo_name")
                    else
                        skipped_names+=("$repo_name")
                        skipped_codes+=("$exit_code")
                        skipped_tails+=("$(printf '%s' "$output" | tail -n 3)")
                    fi
                done < <(find "$selected" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

                echo "ws wt remove: $branch"
                echo "  removed (${#removed[@]}):"
                if [[ ${#removed[@]} -eq 0 ]]; then
                    echo "    (none)"
                else
                    for repo in "${removed[@]}"; do
                        echo "    - $repo"
                    done
                fi
                echo "  skipped (${#skipped_names[@]}):"
                if [[ ${#skipped_names[@]} -eq 0 ]]; then
                    echo "    (none)"
                else
                    for i in "${!skipped_names[@]}"; do
                        echo "    - ${skipped_names[$i]} (exit ${skipped_codes[$i]})"
                        while IFS= read -r line; do
                            [[ -n "$line" ]] && echo "        $line"
                        done <<< "${skipped_tails[$i]}"
                    done
                fi

                if [[ ${#skipped_names[@]} -eq 0 ]]; then
                    if rmdir "$selected" 2>/dev/null; then
                        echo "  branch folder: removed"
                        exit 0
                    else
                        echo "  branch folder: rmdir failed; unexpected content remains in $selected" >&2
                        exit 1
                    fi
                else
                    echo "  branch folder: left in place"
                    exit 1
                fi
                ;;
            *)
                echo "ws wt: unknown subcommand: ${subcommand:-<none>}" >&2
                echo "Usage: ws wt {switch [branch] | remove}" >&2
                exit 1
                ;;
        esac
        ;;
    backstage)
        subcommand="${2:-}"
        case "$subcommand" in
            enter)
                session_name="$3"
                current_path="$4"

                clean=$(basename "$current_path" | tr -cs '[:alnum:]_-' '-' | tr '[:upper:]' '[:lower:]' | sed 's/-*$//')
                target="backstage-${session_name}-${clean}"

                if ! tmux has-session -t "$target" 2>/dev/null; then
                    tmux new-session -d -s "$target" -c "$current_path"
                fi
                tmux set-option -t "$target" @parent_session "$session_name"

                tmux display-popup -B -w 100% -h 100% -E "tmux attach-session -t '$target'"
                ;;
            leave)
                backstage_session="$3"
                client_type="$4"

                if [ "$client_type" = "popup" ]; then
                    tmux detach-client
                    exit 0
                fi

                parent=$(tmux show-options -t "$backstage_session" -qv @parent_session 2>/dev/null)
                if [ -z "$parent" ] || ! tmux has-session -t "$parent" 2>/dev/null; then
                    parent=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^backstage-' | head -1)
                fi
                [ -n "$parent" ] && tmux switch-client -t "$parent" || tmux detach-client
                ;;
        esac
        ;;
esac
