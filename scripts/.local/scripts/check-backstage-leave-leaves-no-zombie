#!/usr/bin/env bash
# Regression test for backstage-popup-leave-leaves-zombie-clients.
#
# Asserts that `ws backstage leave` invoked from a popup-attached nested tmux
# client correctly detaches that client (no zombie left behind).
#
# Exits 0 on PASS, 1 on FAIL.

set -euo pipefail

WS_BIN="${WS_BIN:-$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/ws}"
SOCK="check-bs-$$"
TMP=$(mktemp -d)
cleanup() {
    TMUX= tmux -L "$SOCK" kill-server 2>/dev/null || true
    rm -rf "$TMP"
}
trap cleanup EXIT

cat > "$TMP/conf" <<'EOF'
set -g default-terminal "tmux-256color"
set -g status off
EOF

TMUX= tmux -L "$SOCK" -f "$TMP/conf" new-session -d -s parent -x 200 -y 50
TMUX= tmux -L "$SOCK" new-session -d -s backstage-parent-x -x 200 -y 50
TMUX= tmux -L "$SOCK" set-option -t backstage-parent-x @parent_session parent

cat > "$TMP/outer.py" <<PY
import pty, os, time, fcntl, termios, struct, select
pid, fd = pty.fork()
if pid == 0:
    os.environ['TERM'] = 'xterm-ghostty'
    os.environ['COLUMNS'] = '200'
    os.environ['LINES'] = '50'
    os.environ.pop('TMUX', None)
    os.execvp('tmux', ['tmux', '-L', '$SOCK', 'attach', '-t', 'parent'])
fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack('HHHH', 50, 200, 0, 0))
deadline = time.time() + 60
while time.time() < deadline:
    r, _, _ = select.select([fd], [], [], 0.2)
    if r:
        try: os.read(fd, 65536)
        except OSError: break
PY
python3 -u "$TMP/outer.py" >/dev/null 2>&1 &
OUTER_PID=$!
sleep 2

TMUX= tmux -L "$SOCK" display-popup -t parent -B -w 100% -h 100% -E \
    "tmux -L $SOCK attach-session -t backstage-parent-x" >/dev/null 2>&1 &
POPUP_PID=$!
sleep 2

popup_client_pid=$(TMUX= tmux -L "$SOCK" list-clients \
    -F '#{client_pid} #{client_session}' \
    | awk '$2=="backstage-parent-x"{print $1; exit}')

if [ -z "$popup_client_pid" ]; then
    echo "FAIL: setup did not produce a popup-attached client on backstage-parent-x"
    kill -9 "$OUTER_PID" "$POPUP_PID" 2>/dev/null || true
    exit 1
fi

popup_parent_pid=$(ps -o ppid= -p "$popup_client_pid" 2>/dev/null | tr -d ' ')
popup_parent_cmd=$(ps -o comm= -p "$popup_parent_pid" 2>/dev/null | xargs basename 2>/dev/null)
if [ "$popup_parent_cmd" != "tmux" ]; then
    echo "FAIL: setup — popup-attached client parent should be tmux, got '$popup_parent_cmd'"
    kill -9 "$OUTER_PID" "$POPUP_PID" 2>/dev/null || true
    exit 1
fi

mkdir -p "$TMP/bin"
real_tmux=$(command -v tmux)
cat > "$TMP/bin/tmux" <<EOF
#!/usr/bin/env bash
exec "$real_tmux" -L "$SOCK" "\$@"
EOF
chmod +x "$TMP/bin/tmux"
PATH="$TMP/bin:$PATH" TMUX= "$WS_BIN" backstage leave backstage-parent-x "$popup_client_pid" \
    >/dev/null 2>&1 || true
sleep 1

count_nested_clients() {
    local n=0 pid parent_pid parent_cmd
    while read -r pid; do
        [ -z "$pid" ] && continue
        parent_pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
        [ -z "$parent_pid" ] && continue
        parent_cmd=$(ps -o comm= -p "$parent_pid" 2>/dev/null | xargs basename 2>/dev/null)
        [ "$parent_cmd" = "tmux" ] && n=$((n+1))
    done < <(TMUX= tmux -L "$SOCK" list-clients -F '#{client_pid}' 2>/dev/null)
    echo "$n"
}

remaining=$(count_nested_clients)

kill -9 "$OUTER_PID" "$POPUP_PID" 2>/dev/null || true

if [ "$remaining" -eq 0 ]; then
    echo "PASS: no zombie nested client after leave"
    exit 0
fi

echo "FAIL: $remaining nested-attach client(s) (parent=tmux) still attached after leave"
exit 1
