#!/usr/bin/env bash
# ws: tmux workspace manager.
# Workspaces are tmux sessions. Sessions prefixed with "backstage-" are
# internal and excluded from all workspace listings.
# Typed queries are normalised (spaces and dots → hyphens, trailing hyphens
# stripped) before use as a session name.
#
# Usage:
#   ws [switch]                 fzf-pick or type a workspace name to switch to (or create)
#   ws kill                     fzf-pick a workspace to kill (also kills its backstage sessions and removes its worktrees)
#   ws workspace                print the active workspace name (tmux session name); refuses on backstage / outside tmux
#   ws wt switch [workspace]    switch to the worktree for [workspace] (defaults to the active workspace)
#   ws wt add <repo> [workspace] materialize a worktree for [workspace] in ~/dev/<repo> without changing CWD
#   ws wt remove                fzf-pick a workspace folder under ~/dev/.worktrees and remove every worktree in it;
#                               warns on dirty/unmerged worktrees and prompts before retrying with --force --force-delete

exec tmux-workspace-manager "$@"
