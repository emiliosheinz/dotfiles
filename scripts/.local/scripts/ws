#!/usr/bin/env bash
# ws: tmux workspace manager.
# Workspaces are tmux sessions. Sessions prefixed with "backstage-" are
# internal and excluded from all workspace listings.
# Typed queries are normalised (spaces and dots → hyphens, trailing hyphens
# stripped) before use as a session name.
#
# Usage:
#   ws [switch]              fzf-pick or type a workspace name to switch to (or create)
#   ws kill                  fzf-pick a workspace to kill (also kills its backstage sessions)
#   ws branch                print the active branch (tmux session name); refuses on backstage / outside tmux
#   ws wt switch [branch]    switch to the worktree for [branch] (defaults to current workspace name)
#   ws wt add <repo> [branch] materialize a worktree for [branch] in ~/dev/<repo> without changing CWD
#   ws wt remove             fzf-pick a branch folder under ~/dev/.worktrees and remove every worktree in it

exec tmux-workspace-manager "$@"
